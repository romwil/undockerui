# Copy to ".env" in the repository root (parent of web/). Never commit .env.
# Vite loads these from envDir ".." — see web/vite.config.ts

# Unraid LAN IP (used when building default GraphQL / web GUI URLs)
UNRAID_IP=192.168.1.10

# Optional: sent as x-api-key on proxied /graphql requests during npm run dev only
# UNRAID_KEY=your-unraid-api-key-if-required

# Full GraphQL URL (overrides IP + port when set)
UNRAID_GRAPHQL=http://192.168.1.10:8081/graphql

# Used only when UNRAID_GRAPHQL is unset
UNRAID_GRAPHQL_PORT=8081

# Origin for compose_api.php proxy (http(s)://host[:port])
UNRAID_WEBGUI=http://192.168.1.10

# Optional: override browser GraphQL URL in the production bundle (default is /graphql)
# VITE_GRAPHQL_URL=/graphql

# Copy to .env and fill in. Never commit .env.

UNRAID_IP=192.168.1.10
UNRAID_KEY=your-api-key-here

# Full GraphQL URL (default on Unraid is port 8081)
UNRAID_GRAPHQL=http://192.168.1.10:8081/graphql
UNRAID_GRAPHQL_PORT=8081

UNRAID_WEBUI=http://192.168.1.10:8081

# Optional: baked into production bundle for browser GraphQL URL (same-origin proxy or full URL)
# VITE_GRAPHQL_URL=http://192.168.1.10:8081/graphql

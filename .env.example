# =============================================================================
# UndockerUI — environment variables (repository ROOT, next to package.json)
# =============================================================================
# Copy this file to `.env` and adjust for your Unraid box. Never commit `.env`.
#
# Vite loads these when you run `npm run dev` or `npm run build` from `web/`
# (see web/vite.config.ts: envDir = parent folder).
#
# Two roles:
#   A) UNRAID_*  — read in vite.config.ts ONLY (dev proxy targets + API key header).
#   B) VITE_*    — embedded in the client bundle at build time (must be prefixed VITE_).
#
# Unraid: enabling GraphQL, API keys, Management Access → https://github.com/romwil/undockerui/wiki/Unraid-API-and-keys
# =============================================================================

# -----------------------------------------------------------------------------
# A) Dev server proxy — where Vite forwards /graphql and compose_api.php
# -----------------------------------------------------------------------------

# LAN IP or hostname of your Unraid server (used if UNRAID_GRAPHQL / UNRAID_WEBGUI omitted).
UNRAID_IP=192.168.1.10

# Full GraphQL HTTP URL (scheme + host + port + path). Overrides IP + port below.
# Typical Unraid GraphQL port is 8081; path is usually /graphql
UNRAID_GRAPHQL=http://192.168.1.10:8081/graphql

# Used only when UNRAID_GRAPHQL is unset or empty:
UNRAID_GRAPHQL_PORT=8081

# Unraid **web GUI** origin (scheme + host + port) — used to proxy compose_api.php.
# Include the port Unraid uses in the browser (often 80 or 443), e.g. http://192.168.1.10:80
UNRAID_WEBGUI=http://192.168.1.10

# Optional: Unraid **API key** (Unraid Connect / API access). Dev proxy adds it as
# `x-api-key` on proxied POST /graphql only. Prefer UNRAID_API_KEY; UNRAID_KEY is a legacy alias.
# UNRAID_API_KEY=your-key-here
# UNRAID_KEY=your-key-here

# -----------------------------------------------------------------------------
# B) Production build — optional override for the browser GraphQL URL
# -----------------------------------------------------------------------------
# Default in the built SPA is same-origin `/graphql` (correct when UndockerUI runs
# inside the Unraid web UI). Set this only for unusual deployments (custom domain, split ports).
# VITE_GRAPHQL_URL=https://unraid.example.com/graphql

# Copy relevant lines into `.env` next to docker-compose.yml (same folder).
# Docker Compose automatically loads `.env` when you run `docker compose up` and
# substitutes ${VAR} in docker-compose.yml — those values are then passed into
# the container via the `environment:` block.
#
# You do NOT have to duplicate every variable: if a line is missing from `.env`,
# Compose uses the default after `:-` in compose (often empty = unset in container).

# --- Unraid GraphQL (required for heartbeat / overseer) ---
UNRAID_IP=10.0.0.1
UNRAID_KEY=your-api-key-here
# Optional: full URL if not http://UNRAID_IP:8081/graphql
# UNRAID_GRAPHQL=http://tower.local:8081/graphql
# UNRAID_GRAPHQL_PORT=8081

# Web UI base for Overseer “U” Docker link (no trailing slash)
# UNRAID_WEBUI=http://10.0.0.1

# --- GNR — Galaxy News Radio stream (optional) ---
# GNR_RADIO_URL=https://www.youtube.com/live/...
# Legacy alias still supported:
# WSTE_RADIO_URL=https://...
# YTDLP_JS_RUNTIMES=node

# --- App data directory inside container (compose sets /app/data by default) ---
# VAULT_DATA_DIR=/app/data
